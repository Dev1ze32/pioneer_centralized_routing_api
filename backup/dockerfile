# Backup container — Alpine + postgresql-client for pg_dump + busybox crond
FROM alpine:3.19

# postgresql16-client gives us pg_dump and pg_isready
RUN apk add --no-cache postgresql16-client

# Copy the backup script
COPY backup.sh /usr/local/bin/backup.sh
RUN chmod +x /usr/local/bin/backup.sh

# Install the cron schedule
# busybox crond (already in Alpine) reads from /etc/crontabs/root
# Cron format: minute hour day-of-month month day-of-week command
RUN echo "0 2 * * 0 /usr/local/bin/backup.sh weekly  >> /var/log/backup.log 2>&1" >  /etc/crontabs/root && \
    echo "0 3 1 * * /usr/local/bin/backup.sh monthly >> /var/log/backup.log 2>&1" >> /etc/crontabs/root

# Ensure the log file exists so tail -f works from the start
RUN touch /var/log/backup.log

# Run crond in foreground (-f) at log level 8 (debug) so Docker captures output
# Tail the log file so `docker compose logs backup` shows backup activity
CMD crond -f -l 8 & tail -f /var/log/backup.log