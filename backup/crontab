# Format: min hour day month weekday command

# Weekly backup: Every Sunday at 1:00 AM
0       1       *       *       0       /app/backup.sh weekly >> /var/log/backup.log 2>&1

# Monthly backup: 1st of every month at 2:00 AM
0       2       1       *       *       /app/backup.sh monthly >> /var/log/backup.log 2>&1
